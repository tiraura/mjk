---
// src/layouts/Layout.astro
import '../styles/global.css';
import RightMenu from '../components/RightMenu.astro';
import TopHeader from '../components/TopHeader.astro';

// 1. ClientRouter をインポートします
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja" class="bg-[#0b0b0b] text-[#f5f5f7] antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    
    <!-- 2. headタグの中に配置します -->
    <ClientRouter />
  </head>
  <body class="min-h-screen selection:bg-white/20 selection:text-white">
    <!-- 1カラムレイアウト -->
    <main class="max-w-[800px] mx-auto px-6 md:px-12 py-24 md:py-36">
      <slot />
    </main>

    <TopHeader />
    <RightMenu />
  </body>
</html>