---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja" class="bg-[#0b0b0b] text-[#f5f5f7] antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen selection:bg-white/20 selection:text-white">
    <!-- 
      1カラムレイアウト（PC時に最大横幅 800px、左右に大きな余白、上下に十分なスペース）
    -->
    <main class="max-w-[800px] mx-auto px-6 md:px-12 py-24 md:py-36">
      <slot />
    </main>
  </body>
</html>