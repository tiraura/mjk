---
// src/layouts/Layout.astro
import '../styles/global.css';
import RightMenu from '../components/RightMenu.astro';
import TopHeader from '../components/TopHeader.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<!-- 
  1. htmlタグに「snap-y snap-mandatory」を追加し、
     スクロール時に必ず要素の端にぴったりスナップ（吸着）させます。
-->
<html lang="ja" class="bg-[#0b0b0b] text-[#f5f5f7] antialiased snap-y snap-mandatory scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen selection:bg-white/20 selection:text-white">
    <!-- 
      2. 1カラムのレイアウト
         完璧に画面中央にスナップさせるため、mainタグの上下パディング（py-24など）を外し、
         左右幅だけを制限します。
    -->
    <main class="max-w-[800px] mx-auto px-6 md:px-12">
      <slot />
    </main>

    <TopHeader />
    <RightMenu />
  </body>
</html>