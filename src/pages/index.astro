---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="一人の人間の活動・思考・作品を体験するサイト">
  <!-- 
    space-y-40 は廃止します（各記事が画面いっぱいに広がるため）
  -->
  <div>
    {
      sortedPosts.map(async (post) => {
        const { Content } = await render(post);
        
        return (
          /* 
            各記事を「高さ100%（min-h-screen）」にし、
            スナップの開始位置（snap-start）に設定します。
            さらに「flex flex-col justify-center」で、文字数が少なくても
            記事全体が常に画面の「上下中央」に美しく配置されるようにします。
          */
          <article class="min-h-screen snap-start flex flex-col justify-center py-16">
            <h1 class="text-3xl md:text-5xl font-light tracking-tight text-white mb-4 leading-tight">
              {post.data.title}
            </h1>
            
            <time class="block text-sm text-neutral-500 mb-12 font-mono">
              {post.data.pubDate.toLocaleDateString('ja-JP', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit'
              })}
            </time>
            
            <div class="text-neutral-300 leading-[1.8] space-y-8 text-base md:text-lg">
              <Content />
            </div>
          </article>
        );
      })
    }
  </div>
</Layout>