---
// src/pages/profile.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Profile | Hide">
  <article class="prose prose-invert max-w-none">
    <h1 class="text-3xl md:text-5xl font-light tracking-tight text-white mb-12">
      👤 Profile
    </h1>
    
    <div class="text-neutral-300 leading-relaxed space-y-12 text-base md:text-lg font-light">
      <section class="space-y-4">
        <h2 class="text-2xl text-white font-light">About Me</h2>
        <p>
          ミニマリズム、高級感のあるデザイン、そしてAIをネイティブに活用した開発プロセスに強い関心を持つクリエイターです。
        </p>
      </section>

      <section class="space-y-4">
        <h2 class="text-2xl text-white font-light">Core Interests</h2>
        <ul class="list-disc list-inside space-y-2 text-neutral-400">
          <li>Game Development (Unity / Astro)</li>
          <li>Systematic Trading</li>
          <li>Minimalist UI/UX Design</li>
        </ul>
      </section>
    </div>
  </article>
</Layout>